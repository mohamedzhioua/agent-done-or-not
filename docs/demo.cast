[0.4, "o", "# the agent thinks it's finished and tries to stop...\r\n"]
[1.6, "o", "agent> All tests pass — task complete! ✅\r\n"]
[2.4, "o", "stop-gate: BLOCKED — no proof receipt found for this project\r\n"]
[2.7, "o", "stop-gate: prove your work first:\r\n"]
[2.9, "o", "stop-gate:   bash done-gate.sh capture --label check -- <your test/build/run command>\r\n"]
[4.2, "o", "# so it actually runs the check, through the gate\r\n"]
[5.0, "o", "$ bash done-gate.sh capture --label test -- npm test\r\n"]
